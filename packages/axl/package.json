{
  "name": "@axlsdk/axl",
  "version": "0.3.0",
  "description": "TypeScript SDK for orchestrating Agentic Systems",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0",
    "better-sqlite3": "^9.0.0 || ^10.0.0 || ^11.0.0 || ^12.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.5.1",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "better-sqlite3": "^12.6.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "typescript",
    "orchestration",
    "agentic"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axl-sdk/axl.git",
    "directory": "packages/axl"
  },
  "homepage": "https://github.com/axl-sdk/axl#readme",
  "bugs": {
    "url": "https://github.com/axl-sdk/axl/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
