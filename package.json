{
  "name": "axl-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:e2e": "pnpm --filter axl-tests test:e2e",
    "test:studio": "pnpm --filter axl-tests test:studio",
    "test:smoke": "pnpm --filter axl-tests test:smoke",
    "lint": "eslint packages/*/src/",
    "format": "prettier --write packages/*/src/",
    "format:check": "prettier --check packages/*/src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,css,html,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
